<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>시세이도 × 카페24 | 프리미엄 D2C 전환 제안서</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Noto+Serif+KR:wght@300;400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F8F4EF;
    --warm-white: #FDFAF6;
    --gold: #C9A84C;
    --gold-light: #E8D5A3;
    --gold-muted: #D4B870;
    --charcoal: #1A1814;
    --dark: #2C2820;
    --medium: #5C5448;
    --light: #9A9088;
    --accent-red: #8B2635;
    --accent-blush: #D4A0A0;
    --border: rgba(201,168,76,0.25);
    --section-gap: 120px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--charcoal);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
    line-height: 1.6;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(248,244,239,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), var(--gold-muted));
    transition: width 0.2s ease;
    width: 0%;
  }

  .nav-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.15em;
    color: var(--charcoal);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--medium);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active { color: var(--gold); }

  .nav-cta {
    background: var(--charcoal);
    color: var(--cream) !important;
    padding: 9px 20px;
    border-radius: 2px;
    font-size: 11px !important;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: var(--gold) !important; color: var(--charcoal) !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    background: var(--charcoal);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 80px 60px;
    position: relative;
    overflow: hidden;
  }

  .hero-left::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: 
      radial-gradient(ellipse at 20% 80%, rgba(201,168,76,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(139,38,53,0.08) 0%, transparent 50%);
  }

  .hero-ornament {
    position: absolute;
    top: 60px;
    right: 60px;
    width: 120px;
    height: 120px;
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-ornament::after {
    content: '';
    width: 80px;
    height: 80px;
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 50%;
  }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 400;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(48px, 5vw, 72px);
    font-weight: 300;
    line-height: 1.05;
    color: var(--cream);
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .hero-sub {
    font-size: 15px;
    color: rgba(248,244,239,0.55);
    line-height: 1.7;
    max-width: 400px;
    position: relative;
    z-index: 1;
    font-weight: 300;
  }

  .hero-right {
    background: var(--warm-white);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
    position: relative;
  }

  .hero-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 48px;
  }

  .hero-stat {
    border-left: 2px solid var(--gold);
    padding-left: 20px;
  }

  .hero-stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 38px;
    font-weight: 500;
    color: var(--charcoal);
    line-height: 1;
    margin-bottom: 6px;
  }

  .hero-stat-label {
    font-size: 12px;
    color: var(--light);
    letter-spacing: 0.05em;
    line-height: 1.4;
  }

  .hero-diagnosis-box {
    background: var(--cream);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 28px 32px;
  }

  .hero-diag-title {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .score-bar-wrap {
    margin-bottom: 14px;
  }

  .score-bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--medium);
    margin-bottom: 6px;
  }

  .score-bar {
    height: 4px;
    background: rgba(201,168,76,0.15);
    border-radius: 2px;
    overflow: hidden;
  }

  .score-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-muted));
    border-radius: 2px;
    animation: fillBar 1.5s ease forwards;
    transform-origin: left;
  }

  @keyframes fillBar {
    from { width: 0 !important; }
  }

  /* ── SECTIONS ── */
  section {
    padding: var(--section-gap) 80px;
    position: relative;
  }

  .section-label {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 300;
    line-height: 1.1;
    color: var(--charcoal);
    margin-bottom: 24px;
  }

  .section-lead {
    font-size: 16px;
    color: var(--medium);
    line-height: 1.8;
    max-width: 640px;
    font-weight: 300;
  }

  .divider {
    width: 48px;
    height: 1px;
    background: var(--gold);
    margin: 32px 0;
  }

  /* ── DIAGNOSIS ── */
  #diagnosis {
    background: var(--charcoal);
    color: var(--cream);
    padding: var(--section-gap) 80px;
  }

  #diagnosis .section-title { color: var(--cream); }
  #diagnosis .section-lead { color: rgba(248,244,239,0.6); }
  #diagnosis .divider { background: var(--gold); }

  .diag-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(201,168,76,0.2);
    margin: 48px 0 40px;
  }

  .diag-tab {
    padding: 14px 28px;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(248,244,239,0.4);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    font-family: 'DM Sans', sans-serif;
  }

  .diag-tab.active {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  .diag-panel { display: none; }
  .diag-panel.active { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }

  .diag-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 4px;
    padding: 32px;
  }

  .diag-card-icon {
    width: 40px;
    height: 40px;
    border: 1px solid var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    margin-bottom: 20px;
  }

  .diag-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--cream);
    margin-bottom: 12px;
  }

  .diag-card p {
    font-size: 14px;
    color: rgba(248,244,239,0.5);
    line-height: 1.7;
  }

  .diag-badge {
    display: inline-block;
    margin-top: 16px;
    padding: 5px 14px;
    border: 1px solid rgba(139,38,53,0.5);
    border-radius: 20px;
    font-size: 11px;
    color: var(--accent-blush);
    letter-spacing: 0.08em;
  }

  .diag-badge.opportunity {
    border-color: rgba(201,168,76,0.4);
    color: var(--gold-light);
  }

  /* ── BRAND SCORE ── */
  #brand-score {
    background: var(--warm-white);
    padding: var(--section-gap) 80px;
  }

  .score-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    margin-top: 60px;
  }

  .score-radar {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .score-item {
    display: grid;
    grid-template-columns: 140px 1fr 40px;
    align-items: center;
    gap: 16px;
  }

  .score-name {
    font-size: 13px;
    color: var(--medium);
    letter-spacing: 0.03em;
  }

  .score-track {
    height: 6px;
    background: rgba(201,168,76,0.12);
    border-radius: 3px;
    overflow: hidden;
  }

  .score-fill {
    height: 100%;
    border-radius: 3px;
    animation: fillBar 2s ease forwards;
  }

  .score-fill.high { background: linear-gradient(90deg, var(--gold), #E8C55A); }
  .score-fill.mid { background: linear-gradient(90deg, var(--medium), #8A8078); }
  .score-fill.low { background: linear-gradient(90deg, var(--accent-red), #C04060); }

  .score-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    color: var(--charcoal);
    text-align: right;
  }

  .brand-type-card {
    background: var(--charcoal);
    color: var(--cream);
    padding: 48px;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }

  .brand-type-card::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 200px;
    height: 200px;
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 50%;
  }

  .brand-type-label {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .brand-type-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    font-weight: 300;
    line-height: 1.1;
    color: var(--cream);
    margin-bottom: 24px;
  }

  .brand-type-desc {
    font-size: 14px;
    color: rgba(248,244,239,0.6);
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .brand-tag {
    display: inline-block;
    padding: 6px 16px;
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 20px;
    font-size: 11px;
    color: var(--gold-light);
    margin: 4px;
    letter-spacing: 0.06em;
  }

  /* ── MAGNET STRATEGY ── */
  #magnet {
    background: var(--cream);
    padding: var(--section-gap) 80px;
  }

  .magnet-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 60px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .magnet-cell {
    background: var(--warm-white);
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.3s;
  }

  .magnet-cell:hover {
    background: var(--charcoal);
  }

  .magnet-cell:hover .magnet-letter,
  .magnet-cell:hover .magnet-title,
  .magnet-cell:hover .magnet-body { color: var(--cream); }

  .magnet-cell:hover .magnet-bar { background: var(--gold); }

  .magnet-letter {
    font-family: 'Cormorant Garamond', serif;
    font-size: 72px;
    font-weight: 300;
    color: rgba(201,168,76,0.2);
    line-height: 1;
    margin-bottom: 24px;
    transition: color 0.3s;
  }

  .magnet-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 12px;
    transition: color 0.3s;
  }

  .magnet-body {
    font-size: 13px;
    color: var(--light);
    line-height: 1.7;
    transition: color 0.3s;
  }

  .magnet-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    width: 100%;
    background: var(--border);
    transition: background 0.3s;
  }

  /* ── SUCCESS CASES ── */
  #cases {
    background: var(--charcoal);
    padding: var(--section-gap) 80px;
  }

  #cases .section-title { color: var(--cream); }
  #cases .section-lead { color: rgba(248,244,239,0.5); }
  #cases .divider { background: var(--gold); }

  .cases-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 48px;
  }

  .case-row {
    display: grid;
    grid-template-columns: 60px 1fr 1fr 160px;
    gap: 32px;
    align-items: center;
    padding: 28px 32px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(201,168,76,0.08);
    border-radius: 2px;
    transition: background 0.2s;
    cursor: default;
  }

  .case-row:hover { background: rgba(255,255,255,0.06); }

  .case-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 300;
    color: rgba(201,168,76,0.3);
  }

  .case-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--cream);
  }

  .case-desc {
    font-size: 13px;
    color: rgba(248,244,239,0.45);
    line-height: 1.6;
  }

  .case-result {
    text-align: right;
  }

  .case-kpi {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--gold);
  }

  .case-kpi-label {
    font-size: 11px;
    color: rgba(248,244,239,0.35);
    letter-spacing: 0.08em;
  }

  /* ── ROADMAP ── */
  #roadmap {
    background: var(--warm-white);
    padding: var(--section-gap) 80px;
  }

  .roadmap-timeline {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 60px;
    position: relative;
  }

  .roadmap-phase {
    background: var(--cream);
    padding: 40px 36px;
    position: relative;
    border: 1px solid var(--border);
  }

  .roadmap-phase::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
  }

  .roadmap-phase:nth-child(1)::before { background: var(--gold); }
  .roadmap-phase:nth-child(2)::before { background: var(--medium); }
  .roadmap-phase:nth-child(3)::before { background: var(--accent-red); }

  .phase-period {
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    font-weight: 500;
  }

  .phase-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 24px;
    line-height: 1.2;
  }

  .phase-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .phase-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 13px;
    color: var(--medium);
    line-height: 1.5;
  }

  .phase-item::before {
    content: '─';
    color: var(--gold);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .phase-kpi-box {
    margin-top: 28px;
    padding: 16px 20px;
    background: var(--charcoal);
    border-radius: 2px;
  }

  .phase-kpi-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(248,244,239,0.4);
    margin-bottom: 6px;
  }

  .phase-kpi-val {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: var(--gold);
  }

  /* ── CAFE24 VALUE ── */
  #value {
    background: var(--cream);
    padding: var(--section-gap) 80px;
  }

  .value-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 60px;
    background: var(--border);
  }

  .value-card {
    background: var(--warm-white);
    padding: 36px 28px;
    text-align: center;
  }

  .value-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }

  .value-name {
    font-family: 'Noto Serif KR', serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 10px;
  }

  .value-desc {
    font-size: 12px;
    color: var(--light);
    line-height: 1.6;
  }

  /* ── CTA ── */
  #cta {
    background: var(--charcoal);
    padding: 100px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  #cta::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    border: 1px solid rgba(201,168,76,0.08);
    border-radius: 50%;
  }

  #cta::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    border: 1px solid rgba(201,168,76,0.05);
    border-radius: 50%;
  }

  .cta-eyebrow {
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 300;
    color: var(--cream);
    margin-bottom: 24px;
    line-height: 1.1;
    position: relative;
    z-index: 1;
  }

  .cta-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .cta-sub {
    font-size: 15px;
    color: rgba(248,244,239,0.45);
    margin-bottom: 48px;
    position: relative;
    z-index: 1;
    font-weight: 300;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .btn-primary {
    display: inline-block;
    padding: 18px 48px;
    background: var(--gold);
    color: var(--charcoal);
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-block;
    padding: 18px 48px;
    border: 1px solid rgba(201,168,76,0.4);
    color: var(--cream);
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
  }

  .contact-info {
    margin-top: 48px;
    display: flex;
    gap: 40px;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .contact-item {
    font-size: 12px;
    color: rgba(248,244,239,0.35);
    letter-spacing: 0.05em;
  }

  /* ── FOOTER ── */
  footer {
    background: #111008;
    padding: 32px 80px;
    display: flex;
    justify-content: space-between;
